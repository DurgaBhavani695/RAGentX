# RAGentX Environment Configuration

# --- Groq LLM Configuration ---
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_gsk_key_here

# Recommended models: 
# - llama-3.3-70b-versatile (High performance)
# - llama3-8b-8192 (Fast)
# - mixtral-8x7b-32768
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# --- Vector Store & Embeddings ---
# Local FAISS index path
FAISS_INDEX_PATH=vectorstore/faiss_index

# Free local HuggingFace embedding model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Database & Persistence ---
# Local SQLite database
DATABASE_URL=sqlite:///./ragentx.db

# --- Optional OpenAI Configuration ---
# Only needed if you switch to OpenAI models in the factory
OPENAI_API_KEY=
